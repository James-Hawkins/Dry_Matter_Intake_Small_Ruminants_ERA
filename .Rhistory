{
formula <- de.listify( d.gbr[  r , 'gbr.form'] )
model.return <- gen.glm.model(  train.data ,  formula , d.gbr[r, 'mod.vers'] )
model <- de.listify( model.return )[[1]]
m.stop <- de.listify( model.return[2] )
nu <- de.listify( model.return[3] )
