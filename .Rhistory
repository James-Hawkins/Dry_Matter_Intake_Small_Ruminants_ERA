# store in dataframe
d.gbr[r,  'gbr.model'] <- listify ( model )
d.gbr[r,   'm.stop'] <- m.stop
d.gbr[r, 'nu']  <-   nu
ordered.var.names <- extract.ordered.vars(model)
d.gbr[r, 'gbr.model.train.coef.int']  <- as.numeric(coef(model  )[ordered.var.names[1]] )
